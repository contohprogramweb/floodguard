```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled and build artifacts
*.o
*.obj
*.so
*.a
*.dll
*.exe
*.out

# Dependencies
.venv/
venv/
env/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
coverage/
htmlcov/

# Distribution / packaging
dist/
build/
*.egg-info/
```